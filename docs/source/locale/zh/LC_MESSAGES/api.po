msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_neighbor_pairs:3
msgid "The order of the neighbors to consider. Defaults to 1."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_neighbor_pairs:6
msgid ""
"If True, returns only one representation for each pair (i, j) such that i"
" < j, avoiding duplicates like (j, i). If False, returns all directed "
"pairs. Defaults to True."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_neighbor_pairs:11
msgid "A list of tuples, where each tuple is a pair of neighbor indices."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_neighbors:1
