msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_coordinates:6
msgid "The spatial coordinates as a NumPy array."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_identifier:1
msgid "Gets the abstract identifier of a site by its integer index."
msgstr ""

