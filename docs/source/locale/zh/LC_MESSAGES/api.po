msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_neighbors:3
msgid "The integer index of the center site."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_neighbors:5
msgid ""
"The order of the neighbors, where k=1 corresponds to nearest neighbors "
"(NN), k=2 to next-nearest neighbors (NNN), and so on. Defaults to 1."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_neighbors:9
msgid ""
"A list of integer indices for the neighboring sites. Returns an empty "
"list if neighbors for the given `k` have not been pre-calculated or if "
"the site has no such neighbors."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_site_info:1
msgid "Gets all information for a single site."
msgstr ""

#: of tensorcircuit.templates.lattice.AbstractLattice.get_site_info:3
msgid ""
"This method provides a convenient way to retrieve all relevant data for a"
" site (its index, identifier, and coordinates) by using either its "
"integer index or its unique identifier."
