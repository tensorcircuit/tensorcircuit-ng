"Defaults to 1.0."
msgstr ""

#: of tensorcircuit.templates.lattice.HoneycombLattice.__init__:1
msgid "Initializes the HoneycombLattice."
msgstr ""

#: of tensorcircuit.templates.lattice.KagomeLattice:1
msgid "A 2D Kagome lattice."
msgstr ""

#: of tensorcircuit.templates.lattice.KagomeLattice:3
msgid "This is a lattice with a three-site basis on a triangular Bravais lattice."
msgstr ""

#: of tensorcircuit.templates.lattice.KagomeLattice:5
