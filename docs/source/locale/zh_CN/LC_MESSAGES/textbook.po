"\\vec{v}-2\\vec{v}_{\\perp}=2\\vec{v}_{\\|}-\\vec{v}=2\\vec{a}(\\vec{a}^T"
" \\vec{v})-\\vec{v}=2(\\vec{a}\\vec{a}^T-I)\\cdot \\vec{v}\n"
"\n"
msgstr ""

