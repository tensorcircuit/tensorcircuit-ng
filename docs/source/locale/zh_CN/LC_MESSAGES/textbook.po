"  \\begin{array}{cccccccc}\n"
"    1 & 0 & 0 & 0  & 0 & 0& 0&0 \\\\\n"
"    0 & 1 & 0 & 0 & 0 & 0& 0&0\\\\\n"
"    0 & 0 & 1& 0 & 0 & 0& 0&0\\\\\n"
"    0 & 0 & 0 & 1  & 0 & 0& 0&0\\\\\n"
"     0 & 0 & 0 & 0  & 1 & 0& 0&0\\\\\n"
"      0 & 0 & 0 & 0  & 0 & 1& 0&0\\\\\n"
"       0 & 0 & 0 & 0  & 0 & 0& 0&1\\\\\n"
"        0 & 0 & 0 & 0  & 0 & 0& 1&0\\\\\n"
