msgstr "以包含索引及其频率的元组形式返回计数。"

#: ../../source/faq.rst:270
msgid "``\"count_dict_bin\"``"
msgstr "``\"count_dict_bin\"``"

#: ../../source/faq.rst:271
msgid "Returns counts as a dictionary with binary strings as keys."
msgstr "以二进制字符串为键的字典形式返回计数。"

#: ../../source/faq.rst:278
msgid "``\"count_dict_int\"``"
msgstr "``\"count_dict_int\"``"

#: ../../source/faq.rst:279
msgid "Returns counts as a dictionary with integers as keys."
msgstr "以整数为键的字典形式返回计数。"

