msgid "``\"sample_bin\"``"
msgstr "``\"sample_bin\"``"

#: ../../source/faq.rst:245
msgid "Returns measurement results as a list of binary arrays."
msgstr "以二进制数组列表形式返回测量结果。"

#: ../../source/faq.rst:254
msgid "``\"count_vector\"``"
msgstr "``\"count_vector\"``"

#: ../../source/faq.rst:255
msgid "Returns counts as a vector where index represents the state."
msgstr "以向量形式返回计数，其中索引代表状态。"

#: ../../source/faq.rst:262
msgid "``\"count_tuple\"``"
msgstr "``\"count_tuple\"``"

#: ../../source/faq.rst:263
